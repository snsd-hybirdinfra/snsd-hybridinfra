<svg width="1200" height="800" xmlns="http://www.w3.org/2000/svg">

  <rect width="100%" height="100%" fill="#111827"/>

  <text
    x="60"
    y="80"
    fill="white"
    font-size="36"
    font-family="Segoe UI"
  >
    {{ title }}
  </text>

  <line
    x1="220"
    y1="220"
    x2="220"
    y2="620"
    stroke="#38bdf8"
    stroke-width="6"
  />

{% for step in workflow_steps %}

  <circle
    cx="220"
    cy="{{ 240 + (loop.index0 * 100) }}"
    r="26"
    fill="#38bdf8"
  />

  <text
    x="280"
    y="{{ 248 + (loop.index0 * 100) }}"
    fill="white"
    font-size="22"
    font-family="Segoe UI"
  >
    {{ loop.index }}. {{ step }}
  </text>

{% endfor %}

</svg>
