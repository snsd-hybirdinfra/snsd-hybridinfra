diagram:
  scenario: {{ scenario_name }}
  lifecycle: {{ lifecycle_level }}
  type: architecture-overview
  theme: dark-operational

layers:
  - id: detection
    label: Detection Layer

  - id: continuity
    label: Continuity Layer

  - id: governance
    label: Governance Layer

  - id: coordination
    label: Coordination Layer

  - id: evidence
    label: Evidence Layer

nodes:
  - id: enterprise_degradation
    type: telemetry-source
    layer: detection
    label: Enterprise Degradation

  - id: continuity_coordination
    type: alert-layer
    layer: continuity
    label: Continuity Coordination

  - id: executive_escalation
    type: analysis-layer
    layer: governance
    label: Executive Escalation

  - id: cross_domain_coordination
    type: analysis-layer
    layer: coordination
    label: Cross-Domain Coordination

  - id: continuity_evidence
    type: evidence-layer
    layer: evidence
    label: Continuity Evidence

edges:
  - from: enterprise_degradation
    to: continuity_coordination
    type: alert-flow
    label: continuity activation

  - from: continuity_coordination
    to: executive_escalation
    type: validation-flow
    label: governance visibility

  - from: executive_escalation
    to: cross_domain_coordination
    type: validation-flow
    label: coordination workflow

  - from: cross_domain_coordination
    to: continuity_evidence
    type: evidence-flow
    label: continuity evidence
