<svg width="1200" height="800" xmlns="http://www.w3.org/2000/svg">

  <rect width="100%" height="100%" fill="#0f172a"/>

  <text
    x="60"
    y="80"
    fill="white"
    font-size="36"
    font-family="Segoe UI"
  >
    {{ title }}
  </text>

  <text
    x="60"
    y="130"
    fill="#94a3b8"
    font-size="20"
    font-family="Segoe UI"
  >
    {{ scenario_name }}
  </text>

  <rect
    x="60"
    y="180"
    width="320"
    height="220"
    rx="20"
    fill="#1e293b"
    stroke="#38bdf8"
    stroke-width="2"
  />

  <text
    x="90"
    y="230"
    fill="#38bdf8"
    font-size="24"
    font-family="Segoe UI"
  >
    Modules
  </text>

{% for module in modules %}

  <text
    x="100"
    y="{{ 280 + (loop.index0 * 35) }}"
    fill="white"
    font-size="18"
    font-family="Segoe UI"
  >
    - {{ module }}
  </text>

{% endfor %}

  <rect
    x="460"
    y="180"
    width="320"
    height="220"
    rx="20"
    fill="#1e293b"
    stroke="#22c55e"
    stroke-width="2"
  />

  <text
    x="490"
    y="230"
    fill="#22c55e"
    font-size="24"
    font-family="Segoe UI"
  >
    Adapters
  </text>

{% for adapter in adapters %}

  <text
    x="500"
    y="{{ 280 + (loop.index0 * 35) }}"
    fill="white"
    font-size="18"
    font-family="Segoe UI"
  >
    - {{ adapter }}
  </text>

{% endfor %}

  <rect
    x="860"
    y="180"
    width="280"
    height="320"
    rx="20"
    fill="#1e293b"
    stroke="#f59e0b"
    stroke-width="2"
  />

  <text
    x="890"
    y="230"
    fill="#f59e0b"
    font-size="24"
    font-family="Segoe UI"
  >
    Workflow
  </text>

{% for step in workflow_steps %}

  <text
    x="900"
    y="{{ 280 + (loop.index0 * 45) }}"
    fill="white"
    font-size="18"
    font-family="Segoe UI"
  >
    {{ loop.index }}. {{ step }}
  </text>

{% endfor %}

</svg>
